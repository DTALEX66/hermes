# ═══════════════════════════════════════════════
# Hermes Agent 环境变量（模板）
# 部署后需在此文件填入实际密钥
# ═══════════════════════════════════════════════

# ── LLM Provider ──────────────────────────────
# DeepSeek（官方 Provider — 可选）
# 配置方式: DEEPSEEK_API_KEY in ~/.hermes/.env (provider: deepseek)
# 交互式: hermes setup → 选择 DeepSeek
# Get at: https://platform.deepseek.com/api_keys
# 注意：模板不包含真实密钥；在新电脑上复制为 .env 后自行填写。
DEEPSEEK_API_KEY=

# OpenAI Codex（ChatGPT OAuth — 需无网络限制的环境）
# 配置方式: hermes model → 选择 7. OpenAI / ChatGPT OAuth
# 无需 API Key，通过 OAuth 设备码流登录

# ── CC Switch 代理配置（用于访问 GPT） ────────────
# CC Switch 安装主体不保存在本仓库；请在新电脑自行安装并运行。
# 确保 CC Switch 运行后设置以下代理
HTTPS_PROXY=http://127.0.0.1:7890
HTTP_PROXY=http://127.0.0.1:7890
# OPENROUTER_API_KEY=你的OpenRouter密钥
# ANTHROPIC_API_KEY=你的Claude密钥
# GOOGLE_API_KEY=你的Gemini密钥
# KIMI_API_KEY=你的Kimi密钥

# ── 工具 API ──────────────────────────────────
# GROQ_API_KEY=你的Groq密钥（语音转写用）
# ELEVENLABS_API_KEY=你的ElevenLabs密钥（语音用）
# EXA_API_KEY=你的Exa密钥（网页搜索用）
# TAVILY_API_KEY=你的Tavily密钥（网页搜索用）
